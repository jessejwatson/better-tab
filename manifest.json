{
    "manifest_version": 3,
    "name": "Better Tab",
    "version": "1.0",
    "description": "Personal new tab page with bookmark search and powerups.",
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "icons": {
        "128": "icon.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Add bookmark",
        "default_icon": "icon.png"
    },
    "permissions": ["tabs", "storage"],
    "host_permissions": ["https://duckduckgo.com/*"]
}
