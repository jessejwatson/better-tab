{
    "manifest_version": 3,
    "name": "Better Tab",
    "version": "1.0",
    "description": "Personal new tab page with bookmark search and powerups.",
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "icons": {
        "16": "icons/better_tab_16.png",
        "32": "icons/better_tab_32.png",
        "48": "icons/better_tab_48.png",
        "128": "icons/better_tab_128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Add bookmark",
        "default_icon": "icons/better_tab_128.png"
    },
    "permissions": ["tabs", "storage", "search"]
}
